# LLM Keys
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key_for_opus
ANTHROPIC_API_KEY=your_anthropic_api_key

# Supabase Credentials
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Email
RESEND_API_KEY=re_your_api_key
# Sender must be a Resend-verified domain, or onboarding@resend.dev for testing (only sends to your own account email)
EMAIL_FROM=AI Rank One <onboarding@resend.dev>

# Public site URL (used in certificates, newsletters, social links). No trailing slash.
SITE_URL=https://ai-rank-one.hasnainrazalakhani7272.workers.dev

# Lemon Squeezy — create one product variant per tier in your store.
# The key is the store variant ID; the value is the tier type the webhook maps to.
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret
LEMON_SQUEEZY_API_KEY=your_api_key
LEMON_VARIANT_SINGLE=your_single_course_variant_id
LEMON_VARIANT_BUNDLE=your_5_course_bundle_variant_id
LEMON_VARIANT_ALL=your_all_access_variant_id
