# LLM Keys
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key_for_opus
ANTHROPIC_API_KEY=your_anthropic_api_key

# Supabase Credentials
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Email
RESEND_API_KEY=re_your_api_key
# Sender must be a Resend-verified domain, or onboarding@resend.dev for testing (only sends to your own account email)
EMAIL_FROM=AI Rank One <onboarding@resend.dev>

# Public site URL (used in certificates, newsletters, social links). No trailing slash.
SITE_URL=https://ai-rank-one.hasnainrazalakhani7272.workers.dev

# Dodo Payments (Merchant of Record)
DODO_WEBHOOK_SECRET=your_webhook_signing_secret
# Only 2 products: one for any single course ($39), one for bundle ($149).
# The course_slug is passed as checkout metadata, not as separate products.
DODO_PRODUCT_SINGLE=your_single_course_product_id
DODO_PRODUCT_BUNDLE=your_bundle_product_id
# Set to "true" only after KYC is verified and products are live.
PAYMENT_READY=false
